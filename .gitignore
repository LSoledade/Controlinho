# Build artifacts
pc-remote.exe
pc-remote
*.exe
# editor / stale build backups (e.g. pc-remote.exe~)
*~

# Local CA — now stored in %LocalAppData%\pc-remote, but older versions and the
# dev fallback may drop it next to the binary. NEVER commit the private key:
# anyone with it can issue trusted certs for your phone. Regenerated on first run.
pc-remote-ca.crt
pc-remote-ca.key

# Pairing token (secret). Stored in %LocalAppData%\pc-remote; never commit it.
pc-remote-token

# MSIX packaging build artifacts (staged/packed/signing). The manifest and the
# generated Assets\ ARE committed; these outputs are not.
/pkg/
*.msix
*.pfx
